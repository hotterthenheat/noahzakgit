//@version=5
indicator("Institutional Market Microstructure [Arbor Capital]", overlay=true, max_boxes_count=50)

// --- Webhook Input Receivers (Populated by Python Backend) ---
// In production, these arrive via JSON webhook replacing the default values
var float trap_zone_top    = input.float(0, "Trap Zone Top (Backend)")
var float trap_zone_bottom = input.float(0, "Trap Zone Bottom (Backend)")
var float air_pocket_top   = input.float(0, "Air Pocket Top (Backend)")
var float air_pocket_bottom= input.float(0, "Air Pocket Bottom (Backend)")
var string expected_path   = input.string("Awaiting Data...", "Expected Path")

// --- Rishab-Style Minimalist Aesthetic ---
color trap_color   = color.new(#FF4500, 85) // Neon orange, highly transparent
color pocket_color = color.new(#0074D9, 90) // Institutional blue, highly transparent

// Render Dealer Trap Zones (Speed/Convexity Maximums)
if (trap_zone_top != 0 and trap_zone_bottom != 0)
    box.new(left=bar_index[5], top=trap_zone_top, right=bar_index+10, bottom=trap_zone_bottom, 
            border_color=color.new(#FF4500, 50), border_width=1, bgcolor=trap_color, 
            text="DEALER TRAP", text_color=color.new(#FFFFFF, 50), text_size=size.small, text_halign=text.align_right)

// Render Liquidity Vacuums (Air Pockets)
if (air_pocket_top != 0 and air_pocket_bottom != 0)
    box.new(left=bar_index[5], top=air_pocket_top, right=bar_index+10, bottom=air_pocket_bottom, 
            border_color=color.new(#0074D9, 70), border_width=1, bgcolor=pocket_color, 
            text="AIR POCKET", text_color=color.new(#FFFFFF, 70), text_size=size.small, text_halign=text.align_right)

// --- Floating Glassmorphism Data Table ---
var table dashboard = table.new(position.top_right, 2, 4, border_width=1, border_color=color.new(color.white, 90), bgcolor=color.new(#0A0A0A, 20))

if barstate.islast
    table.cell(dashboard, 0, 0, "SYSTEM REGIME:", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dashboard, 1, 0, "Reflexive / Short Gamma", text_color=color.white, text_size=size.normal, text_halign=text.align_right)
    
    table.cell(dashboard, 0, 1, "FRAGILITY IDX:", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dashboard, 1, 1, "84 (ELEVATED)", text_color=#FF4500, text_size=size.normal, text_halign=text.align_right)
    
    table.cell(dashboard, 0, 2, "INST. CAMPAIGN:", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dashboard, 1, 2, "ACCUMULATION (82%)", text_color=#0074D9, text_size=size.normal, text_halign=text.align_right)
    
    table.cell(dashboard, 0, 3, "EXPECTED PATH:", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dashboard, 1, 3, expected_path, text_color=color.white, text_size=size.normal, text_halign=text.align_right)
